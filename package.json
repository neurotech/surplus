{
  "name": "surplus",
  "version": "0.1.0",
  "description": "WoW Addon Manager CLI for Linux",
  "type": "module",
  "bin": {
    "surplus": "./dist/bin/surplus.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "cli": "tsx bin/surplus.ts",
    "dev": "tsx bin/surplus.ts",
    "lint": "biome check src/ bin/",
    "lint:fix": "biome check --write src/ bin/",
    "prepack": "pnpm run build",
    "start": "node dist/bin/surplus.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "nanospinner": "^1.2.2",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.3.1",
    "yauzl-promise": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
